APP_NAME=InciTya
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=
APP_EXTERNAL_URL=
APP_FRONTEND_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ── Base de données ──────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ── Session ──────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=none
SESSION_SECURE_COOKIE=true

# ── Cache / Queue ─────────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=local

# ── Redis ─────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_PREFIX=smartcity:

# ── Broadcast (Reverb) ────────────────────────────────────────────
BROADCAST_CONNECTION=reverb
BROADCAST_DRIVER=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=6001
REVERB_SCHEME=https

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=30

# ── Mail ──────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="InciTya"

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_MOBILE_REDIRECT_URI=
MOBILE_DEEP_LINK=com.smartcitymobile://auth/callback

# ── Firebase ──────────────────────────────────────────────────────
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json

# ── AI Service ────────────────────────────────────────────────────
AI_SERVICE_URL=
AI_SERVICE_TIMEOUT=30

# ── Telescope ─────────────────────────────────────────────────────
TELESCOPE_ENABLED=false
TELESCOPE_DRIVER=database

# ── Swagger ───────────────────────────────────────────────────────
L5_SWAGGER_USE_ABSOLUTE_PATH=false
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST=
L5_SWAGGER_BASE_PATH=/api
